NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws

# Public-facing OCPP endpoint that charge points dial into (shown on the
# in-app Configuration page). Distinct from NEXT_PUBLIC_WS_URL, which is the
# dashboard's own status websocket.
NEXT_PUBLIC_OCPP_SERVER_URL=ws://localhost:9000/ocpp

# Secret key sent as the x-api-key header on every backend request.
# This value is SERVER-SIDE ONLY — do NOT add the NEXT_PUBLIC_ prefix
# or it will be exposed to the browser bundle.
API_SECRET_KEY=your-secret-api-key-here

# Supabase Auth. Both values are PUBLIC by design (the anon key is safe in the
# browser — Row Level Security governs data access), hence the NEXT_PUBLIC_
# prefix. Find them under Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional, LOCAL DEV ONLY — enables the "Dev only" sign-in shortcut on
# /login (app/auth/dev-login/route.ts), which mints a magic link via the
# Supabase admin API instead of sending an email. Never set this in a
# deployed environment: it bypasses Row Level Security. Find it under
# Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

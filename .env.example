NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws

# Secret key sent as the x-api-key header on every backend request.
# This value is SERVER-SIDE ONLY — do NOT add the NEXT_PUBLIC_ prefix
# or it will be exposed to the browser bundle.
API_SECRET_KEY=your-secret-api-key-here

# Supabase Auth. Both values are PUBLIC by design (the anon key is safe in the
# browser — Row Level Security governs data access), hence the NEXT_PUBLIC_
# prefix. Find them under Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
